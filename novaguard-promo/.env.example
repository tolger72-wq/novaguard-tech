# ═══════════════════════════════════════════════════════════════════════
# NovaGuard Promo Engine — Ortam Değişkenleri
# Kopyala: cp .env.example .env
# Production'da tüm parolaları değiştir.
# ═══════════════════════════════════════════════════════════════════════

# ── Veritabanı ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://promo:promo@db:5432/novaguard_promo
DATABASE_URL_SYNC=postgresql://promo:promo@db:5432/novaguard_promo

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Güvenlik (MUTLAKA değiştir) ─────────────────────────────────────────
SECRET_KEY=gizli-anahtar-buraya-en-az-32-karakter-kullan
ADMIN_API_KEY=admin-paneli-anahtari-buraya          # admin.html'e girilir
CRM_API_KEY=casino-entegrasyon-anahtari-buraya      # casino IT'sine verilir

# ── CORS — production'da casino domain'ini gir ──────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Kampanya ────────────────────────────────────────────────────────────
CAMPAIGN_YEAR=2025

# ── Casino Timezone ─────────────────────────────────────────────────────
# Gürcistan: Asia/Tbilisi | Türkiye: Europe/Istanbul | KKTC: Asia/Nicosia
CASINO_TIMEZONE=Asia/Tbilisi

# ── Uygulama ────────────────────────────────────────────────────────────
DEBUG=false

# ── E-posta (SMTP) — çekiliş sertifikasını misafire mail ile göndermek için ──
# Boş bırakılırsa e-posta özelliği devre dışı kalır (PDF indirme etkilenmez).
# Kurumsal mail sunucusu, Gmail SMTP (uygulama şifresiyle) veya SendGrid/
# Mailgun'un SMTP arayüzü kullanılabilir.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=sertifika@casino-adiniz.com
SMTP_USE_TLS=true
